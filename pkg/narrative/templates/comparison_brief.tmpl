<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{.Title}}</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Merriweather:ital,wght@0,300;0,400;0,700;1,300;1,400&family=Source+Sans+3:wght@300;400;600;700&display=swap');

  :root {
    --navy: #1a2744;
    --cream: #faf8f4;
    --warm-white: #fffefa;
    --amber: #d97706;
    --amber-light: #fef3c7;
    --red: #b91c1c;
    --red-light: #fef2f2;
    --green: #15803d;
    --green-light: #f0fdf4;
    --teal: #0e7490;
    --teal-light: #ecfeff;
    --slate: #475569;
    --slate-light: #f1f5f9;
    --border: #e2e8f0;
    --text: #1e293b;
    --text-secondary: #64748b;
    --serif: 'Merriweather', Georgia, 'Times New Roman', serif;
    --sans: 'Source Sans 3', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: var(--sans);
    font-size: 15px;
    line-height: 1.65;
    color: var(--text);
    background: var(--cream);
  }

  /* ─── COVER BANNER ─── */
  .cb-header {
    background: var(--navy);
    color: white;
    padding: 48px 32px 40px;
    text-align: center;
  }
  .cb-eyebrow {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 16px;
  }
  .cb-header h1 {
    font-family: var(--serif);
    font-size: clamp(24px, 3.5vw, 40px);
    font-weight: 700;
    line-height: 1.2;
    max-width: 700px;
    margin: 0 auto 12px;
  }
  .cb-header .meta {
    font-size: 13px;
    opacity: 0.5;
  }

  /* ─── COMPARISON LAYOUT ─── */
  .cb-body {
    max-width: 1000px;
    margin: 0 auto;
    padding: 48px 32px;
  }

  .section-heading {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--navy);
    border-bottom: 2px solid var(--navy);
    padding-bottom: 8px;
    margin-bottom: 24px;
    margin-top: 40px;
  }

  /* ─── NARI COMPARISON STRIP ─── */
  .nari-comparison {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 24px;
    align-items: start;
    margin-bottom: 40px;
  }
  .nari-card {
    background: var(--warm-white);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px 28px;
  }
  .nari-card.critical { border-top: 4px solid var(--red); }
  .nari-card.warning  { border-top: 4px solid var(--amber); }
  .nari-card.neutral  { border-top: 4px solid var(--teal); }
  .nari-card.positive { border-top: 4px solid var(--green); }
  .nari-card-name {
    font-family: var(--serif);
    font-size: 18px;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 4px;
  }
  .nari-card-geoid {
    font-size: 11px;
    color: var(--text-secondary);
    margin-bottom: 16px;
  }
  .nari-card-score {
    font-family: var(--serif);
    font-size: 44px;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 4px;
  }
  .nari-card.critical .nari-card-score { color: var(--red); }
  .nari-card.warning  .nari-card-score { color: var(--amber); }
  .nari-card.neutral  .nari-card-score { color: var(--teal); }
  .nari-card.positive .nari-card-score { color: var(--green); }
  .nari-card-tier {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-secondary);
  }
  .vs-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--serif);
    font-size: 28px;
    font-weight: 300;
    color: var(--text-secondary);
    padding-top: 32px;
  }

  /* ─── INDICATOR COMPARISON TABLE ─── */
  .comparison-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
    margin-bottom: 32px;
  }
  .comparison-table th {
    background: var(--navy);
    color: white;
    padding: 10px 16px;
    text-align: left;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  .comparison-table th:not(:first-child) { text-align: right; }
  .comparison-table td {
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
    vertical-align: middle;
  }
  .comparison-table tr:last-child td { border-bottom: none; }
  .comparison-table tr:nth-child(even) td { background: var(--warm-white); }
  .comparison-table .ind-name-col {
    font-weight: 600;
    color: var(--navy);
  }
  .comparison-table .val-col {
    text-align: right;
    font-weight: 700;
    font-family: var(--serif);
    font-size: 16px;
  }
  .comparison-table .val-col.critical { color: var(--red); }
  .comparison-table .val-col.warning  { color: var(--amber); }
  .comparison-table .val-col.positive { color: var(--green); }

  /* ─── POLICY LEVERS ─── */
  .policy-levers-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 32px;
  }
  @media (max-width: 680px) {
    .policy-levers-grid { grid-template-columns: 1fr; }
    .nari-comparison { grid-template-columns: 1fr; }
    .vs-divider { padding: 8px 0; }
  }
  .policy-lever {
    background: var(--amber-light);
    border: 1px solid #fde68a;
    border-left: 4px solid var(--amber);
    border-radius: 10px;
    padding: 18px 20px;
  }
  .policy-lever-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #92400e;
    margin-bottom: 6px;
  }
  .policy-lever-title {
    font-size: 15px;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 6px;
  }
  .policy-lever p {
    font-size: 13px;
    line-height: 1.6;
    color: #78350f;
    margin-bottom: 8px;
  }
  .policy-lever p:last-child { margin-bottom: 0; }
  .policy-lever .evidence-list {
    list-style: none;
    padding: 0;
    margin: 8px 0 0;
    font-size: 12px;
    color: #78350f;
  }
  .policy-lever .evidence-list li {
    padding: 4px 0 4px 16px;
    position: relative;
    line-height: 1.4;
  }
  .policy-lever .evidence-list li::before {
    content: '\2192';
    position: absolute;
    left: 0;
    color: var(--amber);
    font-weight: 700;
  }

  /* ─── FOOTNOTES ─── */
  .footnotes {
    border-top: 1px solid var(--border);
    padding-top: 28px;
    margin-top: 40px;
    font-size: 12px;
    color: var(--text-secondary);
  }
  .footnotes h3 {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--navy);
    margin-bottom: 12px;
  }
  .footnotes ul {
    padding-left: 18px;
    line-height: 1.8;
  }
  .footnotes li { margin-bottom: 3px; }

  .generated-stamp {
    font-size: 11px;
    color: var(--text-secondary);
    opacity: 0.45;
    margin-top: 12px;
  }

  @media print {
    .cb-header { page-break-after: always; }
    .comparison-table { break-inside: avoid; }
    .policy-lever { break-inside: avoid; }
    body { font-size: 10pt; }
  }
</style>
</head>
<body>

<!-- HEADER -->
<header class="cb-header">
  <div class="cb-eyebrow">Comparison Brief &middot; {{.ScopeName}}</div>
  <h1>{{.Title}}</h1>
  <div class="meta">
    Policy Data Infrastructure &middot; {{.ScopeName}} &middot; {{.GeneratedAt.Format "2006"}}
  </div>
</header>

<main class="cb-body">

{{if ge (len .Chapters) 2}}
{{$ch1 := index .Chapters 0}}
{{$ch2 := index .Chapters 1}}

<!-- NARI side-by-side -->
<div class="section-heading">NARI Comparison</div>
<div class="nari-comparison">
  <div class="nari-card {{severity $ch1.Geography.NARITier}}">
    <div class="nari-card-name">{{$ch1.Geography.Name}}</div>
    <div class="nari-card-geoid">GEOID: {{$ch1.Geography.GEOID}}</div>
    <div class="nari-card-score">{{formatOrdinal $ch1.Geography.NARIPercentile}}</div>
    <div class="nari-card-tier">{{tierLabel $ch1.Geography.NARITier}}</div>
  </div>
  <div class="vs-divider">vs</div>
  <div class="nari-card {{severity $ch2.Geography.NARITier}}">
    <div class="nari-card-name">{{$ch2.Geography.Name}}</div>
    <div class="nari-card-geoid">GEOID: {{$ch2.Geography.GEOID}}</div>
    <div class="nari-card-score">{{formatOrdinal $ch2.Geography.NARIPercentile}}</div>
    <div class="nari-card-tier">{{tierLabel $ch2.Geography.NARITier}}</div>
  </div>
</div>

<!-- Indicator comparison table -->
{{if or $ch1.Indicators $ch2.Indicators}}
<div class="section-heading">Indicator Comparison</div>
<table class="comparison-table">
  <thead>
    <tr>
      <th style="width:35%">Indicator</th>
      <th>{{$ch1.Geography.Name}}</th>
      <th>{{$ch2.Geography.Name}}</th>
    </tr>
  </thead>
  <tbody>
    <!-- Income -->
    <tr>
      <td class="ind-name-col">Median Household Income</td>
      <td class="val-col">{{formatCurrency $ch1.Geography.MedianIncome}}</td>
      <td class="val-col">{{formatCurrency $ch2.Geography.MedianIncome}}</td>
    </tr>
    <!-- Poverty rate -->
    <tr>
      <td class="ind-name-col">Poverty Rate</td>
      <td class="val-col">{{formatPct $ch1.Geography.PovertyRate}}</td>
      <td class="val-col">{{formatPct $ch2.Geography.PovertyRate}}</td>
    </tr>
    <!-- Uninsured rate -->
    <tr>
      <td class="ind-name-col">Uninsured Rate</td>
      <td class="val-col">{{formatPct $ch1.Geography.UninsuredRate}}</td>
      <td class="val-col">{{formatPct $ch2.Geography.UninsuredRate}}</td>
    </tr>
    <!-- Cost burden -->
    <tr>
      <td class="ind-name-col">Cost Burden Rate</td>
      <td class="val-col">{{formatPct $ch1.Geography.CostBurdenRate}}</td>
      <td class="val-col">{{formatPct $ch2.Geography.CostBurdenRate}}</td>
    </tr>
    <!-- Eviction rate -->
    <tr>
      <td class="ind-name-col">Eviction Filing Rate</td>
      <td class="val-col">{{formatRate $ch1.Geography.EvictionRate}}</td>
      <td class="val-col">{{formatRate $ch2.Geography.EvictionRate}}</td>
    </tr>
    <!-- Chronic absence -->
    <tr>
      <td class="ind-name-col">Chronic Absence Rate</td>
      <td class="val-col">{{formatPct $ch1.Geography.ChronicAbsence}}</td>
      <td class="val-col">{{formatPct $ch2.Geography.ChronicAbsence}}</td>
    </tr>
    <!-- % POC -->
    <tr>
      <td class="ind-name-col">% People of Color</td>
      <td class="val-col">{{formatPct $ch1.Geography.PctPOC}}</td>
      <td class="val-col">{{formatPct $ch2.Geography.PctPOC}}</td>
    </tr>
  </tbody>
</table>
{{end}}

<!-- Policy levers -->
{{if or $ch1.PolicyLevers $ch2.PolicyLevers}}
<div class="section-heading">Policy Levers</div>
<div class="policy-levers-grid">
  {{range $ch1.PolicyLevers}}
  <div class="policy-lever">
    <div class="policy-lever-label">{{$ch1.Geography.Name}} &middot; {{upper .Category}}</div>
    <div class="policy-lever-title">{{.Title}}</div>
    <p>{{.Description}}</p>
    {{if .Evidence}}
    <ul class="evidence-list">
      {{range .Evidence}}<li>{{.}}</li>{{end}}
    </ul>
    {{end}}
  </div>
  {{end}}
  {{range $ch2.PolicyLevers}}
  <div class="policy-lever">
    <div class="policy-lever-label">{{$ch2.Geography.Name}} &middot; {{upper .Category}}</div>
    <div class="policy-lever-title">{{.Title}}</div>
    <p>{{.Description}}</p>
    {{if .Evidence}}
    <ul class="evidence-list">
      {{range .Evidence}}<li>{{.}}</li>{{end}}
    </ul>
    {{end}}
  </div>
  {{end}}
</div>
{{end}}

{{else}}
<!-- Fallback: fewer than 2 chapters -->
<p style="padding:40px;text-align:center;color:var(--text-secondary);">
  A comparison brief requires at least two chapters. Only {{len .Chapters}} chapter(s) were generated.
</p>
{{end}}

<!-- Methodology -->
{{if .Methodology}}
<div class="section-heading">Methodology</div>
<p style="font-size:14px;line-height:1.8;color:var(--text-secondary);margin-bottom:24px;">{{.Methodology}}</p>
{{end}}

<!-- Data sources -->
{{if .DataSources}}
<div class="footnotes">
  <h3>Data Sources</h3>
  <ul>{{range .DataSources}}<li>{{.}}</li>{{end}}</ul>
</div>
{{end}}

<p class="generated-stamp">
  Generated {{.GeneratedAt.Format "January 2, 2006 at 15:04 UTC"}} &middot; Policy Data Infrastructure
</p>

</main>
</body>
</html>
